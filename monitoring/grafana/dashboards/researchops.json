{
  "title": "ResearchOps \u2014 HTCondor SLO Dashboard",
  "uid": "researchops-slo",
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Job Success Rate (30m SLO: 99.5%)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "htcondor:job_submission_success_rate:30m * 100",
          "legendFormat": "Success Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.5
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Jobs in Queue",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "htcondor_schedd_jobs_idle",
          "legendFormat": "Idle"
        },
        {
          "expr": "htcondor_schedd_jobs_running",
          "legendFormat": "Running"
        },
        {
          "expr": "htcondor_schedd_jobs_held",
          "legendFormat": "Held"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pool Slots",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "htcondor_pool_slots_total",
          "legendFormat": "Total"
        },
        {
          "expr": "htcondor_pool_slots_busy",
          "legendFormat": "Busy"
        },
        {
          "expr": "htcondor_pool_slots_idle",
          "legendFormat": "Idle"
        }
      ]
    },
    {
      "id": 5,
      "title": "Node CPU Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "node:cpu_usage:5m",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 6,
      "title": "Node Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "node:memory_usage:current",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 7,
      "title": "Scrape Targets Up",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(up)",
          "legendFormat": "Targets Up"
        }
      ]
    },
    {
      "id": 8,
      "title": "Node Disk Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 12,
        "w": 18,
        "h": 4
      },
      "targets": [
        {
          "expr": "node:disk_usage:current",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 9,
      "title": "VM Health",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(up{instance=~\"(submit-node|central-manager|execute-node-1|execute-node-2|nfs-server|monitoring):9100\"})",
          "legendFormat": "ResearchOps VMs UP"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "green",
                "value": 6
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "6": {
                  "text": "6/6 UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 10,
      "title": "Down VMs",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "6 - sum(up{instance=~\"(submit-node|central-manager|execute-node-1|execute-node-2|nfs-server|monitoring):9100\"})",
          "legendFormat": "Down ResearchOps VMs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "0 Down",
                  "color": "green"
                }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 11,
      "title": "Proxmox CPU Usage",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{job=\"proxmox-host\",mode=\"idle\"}[5m])))",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
